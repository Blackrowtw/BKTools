{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",

  "name": "${name}",
  "description": "My fabric mods to learn Java. Built with Fallen_Breath's fabric mod template.",
  "authors": ["BlacKrowtw"],
  "contact": {
    "homepage": "https://modrinth.com",
    "sources": "https://github.com/Fallen-Breath/fabric-mod-template"
  },

  "icon": "assets/bk_tools/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": ["me.blackrowtw.bk_tools.BKTools"],
    "client": ["me.blackrowtw.bk_tools.BKToolsClient"]
  },
  "mixins": [
    {
      "config": "bk_tools.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.11.4",
    "minecraft": "${minecraft_dependency}",
    "malilib": "${malilib_dependency}"
  }
}
