{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",

  "name": "${name}",
  "description": "A Minecraft Fabric mod built on Fallen_Breath's fabric-mod-template. Uses the malilib library by masa and sakura-ryoko.",
  "authors": ["BlacKrowtw"],
  "contact": {
    "homepage": "https://github.com/Blackrowtw",
    "sources": "https://github.com/Blackrowtw/BKTools"
  },

  "icon": "assets/bk_tools/icon.png",

  "environment": "client",
  "entrypoints": {
    "main": ["me.blackrowtw.bk_tools.BKTools"],
    "client": ["me.blackrowtw.bk_tools.BKToolsClient"],
    "modmenu": ["me.blackrowtw.bk_tools.mod_compat.ModMenu"]
  },
  "mixins": [
    {
      "config": "bk_tools.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.11.4",
    "fabric-api-base": "*",
    "fabric-resource-loader-v1": "*",
    "minecraft": "${minecraft_dependency}",
    "malilib": "${malilib_dependency}"
  }
}
